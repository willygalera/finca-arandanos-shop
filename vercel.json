{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["gru1"],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [
    {
      "source": "/tienda",
      "destination": "/shop",
      "permanent": true
    },
    {
      "source": "/catalogo",
      "destination": "/shop",
      "permanent": true
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://fincadearandanos.vercel.app"
  }
}
