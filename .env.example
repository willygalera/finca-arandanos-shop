# ============================================
# FINCA DE ARÁNDANOS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ── SUPABASE ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── STRIPE ────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Finca de Arándanos

# ── WHATSAPP (Twilio or Meta) ─────────────────
WHATSAPP_PHONE_NUMBER=+1234567890
WHATSAPP_API_TOKEN=your-token

# ── INSTAGRAM ─────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
INSTAGRAM_USER_ID=your-user-id

# ── EMAIL (Resend) ────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@fincadearandanos.com

# ── ADMIN ─────────────────────────────────────
ADMIN_EMAIL=admin@fincadearandanos.com
